# Mailer placeholders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASSWORD=change-me
MAIL_FROM=no-reply@example.com

# Upload/static paths
UPLOAD_DIR=uploads
STATIC_BASE_URL=http://localhost:4000
