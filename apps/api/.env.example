# API server
PORT=4000
CLIENT_URL=http://localhost:3000

# Migration/testing database only. Do not use production DB during development.
DATABASE_URL=postgres://user:password@localhost:5432/twb_migration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twb_migration
DB_USER=twb_user
